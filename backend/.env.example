# ─────────────────────────────────────────────
# AgriSubsidy System v2.0 — Environment Config
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agrisubsidy_db
DB_USER=postgres
DB_PASSWORD=YOUR_POSTGRES_PASSWORD_HERE

# JWT Secrets (change these — min 32 chars each)
JWT_SECRET=agrisubsidy_access_token_secret_change_me_now
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=agrisubsidy_refresh_token_secret_change_me_now
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# File uploads
UPLOAD_PATH=./uploads
LOG_LEVEL=info
